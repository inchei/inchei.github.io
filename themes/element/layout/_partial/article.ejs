<% if (post.cover_url){ %><div class="cover"></div><img class="cover" src="<%= post.cover_url %>" /><% } %>
<article id="<%= post.layout %>-<%= post.slug %>"
  class="article white-box article-type-<%= post.layout %>"
  itemscope itemprop="blogPost">

  <header class="article-header">
    <h1 class="article-title" itemprop="name">
      <%= post.title %>
    </h1>
    <div class="article-meta">
      <time class="article-time" dateshort="<%= post.date %>" datetime="<%= date_xml(post.date) %>" itemprop="datePublished">
        <%= dateLunar(date(post.date)) %>
      </time>
      <% if (post.updated){ %>
      ，<time class="article-time" dateshort="<%= post.date %>" datetime="<%= date_xml(post.updated) %>" itemprop="dateUpdated">
        <%= dateLunar(date(post.updated)) %>
      </time>
      <% } %>
    </div>
  </header>

  <div class="article-entry" itemprop="articleBody">
    <%- post.content %>
  </div>
  
  <div class="article-tags">
    <% if (post.tags && post.tags.length){ %>
      <%- list_tags(post.tags, {
        show_count: false,
        style: 'none',
        separator: ''
      }) %>
    <% } %>
  </div>

  <% if (post.comments && (theme.disqus_shortname || theme.valine.enable || config.disqus_shortname)){ %>
  <section id="comments" class="white-box">
    <% if (theme.disqus_shortname || config.disqus_shortname){ %>
      <div id="disqus_thread">
        <noscript>Please enable JavaScript to view the <a href="//disqus.com/?ref_noscript">comments powered by Disqus.</a></noscript>
      </div>
    <% } %>
	</section>
	<% } %>

</article>
